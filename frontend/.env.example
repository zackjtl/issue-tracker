# Backend API URL
# Set this to the full base URL of the backend API (without trailing slash).
# When set, the frontend makes direct requests to this URL and the Vite dev-server
# proxy is disabled. When unset, the proxy forwards /api → http://localhost:8000.
# Example (production): VITE_API_URL=https://issue-tracker.railway.app/api
VITE_API_URL=

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
