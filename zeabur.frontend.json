{
  "$schema": "https://api.zeabur.com/schema.json",
  "build": {
    "method": "nixpacks",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_20", "npm.packages.nodejs_20"]
        },
        "install": {
          "cmds": ["npm install"]
        },
        "build": {
          "cmds": ["npm run build"]
        }
      }
    }
  },
  "deploy": {
    "regions": ["ap-northeast"],
    "plan": "free"
  },
  "environmentVariables": [
    "VITE_SUPABASE_URL",
    "VITE_SUPABASE_ANON_KEY",
    "VITE_API_URL"
  ]
}
