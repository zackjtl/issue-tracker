# ============================================
# Issue Tracker - Environment Variables
# ============================================

# ============================================
# Supabase Configuration (Zeabur)
# ============================================
SUPABASE_URL=https://your-supabase.zeabur.app
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Backend Environment Variables
# ============================================
# Primary frontend origin — merged into the CORS allowed-origins list.
FRONTEND_URL=https://your-frontend.zeabur.app

# Comma-separated list of additional allowed CORS origins.
# The default already includes localhost:3000, localhost:5173, railway.com,
# and railway.app. Override this to restrict or extend the list.
# Example: CORS_ORIGINS=http://localhost:3000,https://your-frontend.zeabur.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://railway.com,https://railway.app

# ============================================
# Frontend Environment Variables
# ============================================
VITE_SUPABASE_URL=https://your-supabase.zeabur.app
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL (for frontend to call backend)
VITE_API_URL=https://your-backend.zeabur.app
