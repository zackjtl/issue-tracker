# ============================================
# Issue Tracker - Environment Variables
# ============================================

# App Settings
APP_NAME=Issue Tracker
VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
BACKEND_PORT=8000

# ============================================
# Supabase Configuration (Zeabur)
# ============================================
SUPABASE_URL=https://your-supabase.zeabur.app
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Frontend URL (for CORS)
# ============================================
# Your Zeabur frontend URL (e.g., https://issue-tracker.zeabur.app)
FRONTEND_URL=https://your-frontend.zeabur.app

# ============================================
# Database
# ============================================
# For Zeabur, use Supabase PostgreSQL or local SQLite
DATABASE_URL=sqlite+aiosqlite:///./data/issue_tracker.db

# ============================================
# Frontend Environment Variables
# ============================================
# The Supabase URL for frontend
VITE_SUPABASE_URL=https://your-supabase.zeabur.app
VITE_SUPABASE_ANON_KEY=your-anon-key

# The backend API URL (for production)
# Leave empty for local development (uses proxy)
VITE_API_URL=https://your-backend.zeabur.app/api
